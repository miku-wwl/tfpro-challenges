[profile tfpro-source]
region = us-east-1
# credential_process / SSO / instance role 等标准机制应在工作站外配置。
# 本文件故意不包含任何 access key 或 secret。

[profile tfpro-recovery]
region = us-west-2
role_arn = arn:aws:iam::222222222222:role/TerraformRecoveryReadWrite
source_profile = tfpro-source
external_id = obtain-from-secret-manager-not-from-git

