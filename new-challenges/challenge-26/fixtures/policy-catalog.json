{
  "artifact-publisher": {
    "actions": ["s3:GetObject", "s3:PutObject"],
    "resources": ["arn:aws:s3:::tfpro-artifacts/*"]
  },
  "readonly-audit": {
    "actions": ["dynamodb:DescribeTable", "dynamodb:GetItem", "dynamodb:Query"],
    "resources": ["arn:aws:dynamodb:us-east-1:000000000000:table/tfpro-ledger"]
  },
  "security-events": {
    "actions": ["sns:GetTopicAttributes", "sns:Publish"],
    "resources": ["arn:aws:sns:us-east-1:000000000000:tfpro-security-events"]
  }
}

