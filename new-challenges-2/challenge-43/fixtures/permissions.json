{
  "schema_version": 1,
  "entries": [
    {
      "id": "artifact-reader",
      "owner": "platform-team",
      "trust_services": ["ec2.amazonaws.com"],
      "statements": [
        {
          "sid": "ListArtifacts",
          "effect": "Allow",
          "actions": ["s3:ListBucket"],
          "resources": ["arn:aws:s3:::tfpro-c43-artifacts"]
        },
        {
          "sid": "ReadArtifacts",
          "effect": "Allow",
          "actions": ["s3:GetObject"],
          "resources": ["arn:aws:s3:::tfpro-c43-artifacts/*"]
        }
      ]
    },
    {
      "id": "queue-publisher",
      "owner": "delivery-team",
      "trust_services": ["lambda.amazonaws.com", "ecs-tasks.amazonaws.com"],
      "statements": [
        {
          "sid": "PublishEvents",
          "effect": "Allow",
          "actions": ["sqs:GetQueueAttributes", "sqs:SendMessage"],
          "resources": ["arn:aws:sqs:us-east-1:000000000000:tfpro-c43-events"]
        }
      ]
    }
  ]
}
