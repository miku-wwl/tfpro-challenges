{
  "entries": [
    {
      "owner": "delivery-team",
      "statements": [
        {
          "resources": ["arn:aws:sqs:us-east-1:000000000000:tfpro-c43-events"],
          "actions": ["sqs:SendMessage", "sqs:GetQueueAttributes"],
          "effect": "Allow",
          "sid": "PublishEvents"
        }
      ],
      "trust_services": ["ecs-tasks.amazonaws.com", "lambda.amazonaws.com"],
      "id": "queue-publisher"
    },
    {
      "statements": [
        {
          "resources": ["arn:aws:s3:::tfpro-c43-artifacts/*"],
          "actions": ["s3:GetObject"],
          "effect": "Allow",
          "sid": "ReadArtifacts"
        },
        {
          "resources": ["arn:aws:s3:::tfpro-c43-artifacts"],
          "actions": ["s3:ListBucket"],
          "effect": "Allow",
          "sid": "ListArtifacts"
        }
      ],
      "id": "artifact-reader",
      "trust_services": ["ec2.amazonaws.com"],
      "owner": "platform-team"
    }
  ],
  "schema_version": 1
}
